{
  "$schema": "./node_modules/@angular/service-worker/config/schema.json",
  "index": "/index.html",
  "assetGroups": [
    {
      "name": "app",
      "installMode": "prefetch",
      "resources": {
        "files": [
          "/index.html",
          "/manifest.webmanifest",
          "/icon.svg",
          "/icon-192x192.png",
          "/icon-512x512.png",
          "/*.css",
          "/*.js"
        ]
      }
    },
    {
      "name": "assets",
      "installMode": "lazy",
      "updateMode": "prefetch",
      "resources": {
        "files": [
          "/assets/**",
          "/.well-known/**"
        ]
      }
    },
    {
      "name": "external-assets",
      "installMode": "prefetch",
      "updateMode": "prefetch",
      "resources": {
        "urls": [
          "https://fonts.googleapis.com/**",
          "https://fonts.gstatic.com/**",
          "https://cdn.jsdelivr.net/npm/jsqr@1.4.0/dist/jsQR.js"
        ]
      }
    },
    {
      "name": "lazy-assets",
      "installMode": "lazy",
      "updateMode": "prefetch",
      "resources": {
        "urls": [
          "https://cdn.jsdelivr.net/npm/tesseract.js@5/dist/**",
          "https://tessdata.projectnaptha.com/**",
          "https://www.transparenttextures.com/patterns/**"
        ]
      }
    }
  ],
  "dataGroups": [
    {
      "name": "api-runtime",
      "urls": [
        "/api/**"
      ],
      "cacheConfig": {
        "strategy": "freshness",
        "maxSize": 50,
        "maxAge": "1h",
        "timeout": "5s"
      }
    }
  ]
}
